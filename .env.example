# Database configuration (PostgreSQL)
DATABASE_URL=postgres://user:password@host:port/db

# Authentication
JWT_SECRET=your_jwt_secret_here

# Backend Configuration (Azure App Service)
PORT=8080
# FRONTEND_URL is used by CORS and Socket.IO to whitelist the frontend domain
FRONTEND_URL=https://your-frontend-url.azurestaticapps.net

# Frontend Configuration (Azure Static Web Apps)
# VITE_API_URL should point to your deployed backend App Service URL
VITE_API_URL=https://your-backend-url.azurewebsites.net
